---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact — Remoria"
  description="Neem contact op met Remoria. Wij helpen u graag verder."
>
  <Navbar />

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="contact-hero">
    <div class="container">
      <div class="contact-hero__inner" data-reveal>
        <p class="eyebrow">Contact</p>
        <h1 class="contact-hero__title">
          Hoe kunnen<br />we helpen?
        </h1>
        <p class="contact-hero__sub">
          Hebt u een vraag, wilt u samenwerken of gewoon kennismaken?
          We horen graag van u.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       TWO-COLUMN BODY
  ══════════════════════════════════════════════ -->
  <section class="contact-body">
    <div class="container contact-body__grid">

      <!-- LEFT -->
      <aside class="contact-info" data-reveal>

        <div class="info-block">
          <div class="info-block__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="info-block__label">E-mail</p>
            <a href="mailto:hello@remoria.eu" class="info-block__value">
              hello@remoria.eu
            </a>
          </div>
        </div>

        <div class="info-divider" aria-hidden="true"></div>

        <div class="info-block info-block--meet">
          <div class="info-block__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <div>
            <p class="info-block__label">Plan een gesprek</p>
            <p class="info-block__desc">
              Bent u uitvaartprofessional en wilt u Remoria ontdekken?
              Plan een vrijblijvende kennismaking.
            </p>
            <button
              type="button"
              class="info-btn"
              data-cal-link="remoria/30min"
              data-cal-namespace="30min"
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
            >
              Bekijk beschikbaarheid
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>

      </aside>

      <!-- RIGHT: FORM -->
      <div class="contact-form-wrap" data-reveal data-reveal-delay="80">
        <form class="contact-form" novalidate>

          <div class="form-row form-row--2">
            <div class="form-field">
              <label class="form-label" for="naam">Naam</label>
              <input
                class="form-input"
                type="text"
                id="naam"
                name="naam"
                placeholder="Uw volledige naam"
                autocomplete="name"
                required
              />
            </div>
            <div class="form-field">
              <label class="form-label" for="email">E-mail</label>
              <input
                class="form-input"
                type="email"
                id="email"
                name="email"
                placeholder="uw@email.be"
                autocomplete="email"
                required
              />
            </div>
          </div>

          <div class="form-field">
            <label class="form-label" for="afdeling">Afdeling</label>
            <div class="form-select-wrap">
              <select class="form-input form-select" id="afdeling" name="afdeling">
                <option value="algemeen" selected>Algemeen</option>
                <option value="sales">Sales</option>
                <option value="support">Support</option>
              </select>
              <svg class="form-select-arrow" width="16" height="16" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

          <div class="form-field">
            <label class="form-label" for="bericht">Bericht</label>
            <textarea
              class="form-input form-textarea"
              id="bericht"
              name="bericht"
              placeholder="Hoe kunnen we u helpen?"
              rows="5"
              required
            ></textarea>
          </div>

          <button type="submit" class="form-submit">
            Verstuur bericht
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

        </form>
      </div>

    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.eu/embed/embed.js", "init");
  Cal("init", "30min", {origin:"https://app.cal.eu"});
  Cal.config = Cal.config || {};
  Cal.config.forwardQueryParams = true;

  Cal.ns["30min"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
</script>

<script>
  (function () {
    const elements = document.querySelectorAll<HTMLElement>('[data-reveal]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.dataset.revealDelay ? parseInt(el.dataset.revealDelay) : 0;
            setTimeout(() => el.classList.add('is-visible'), delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.12 }
    );
    elements.forEach((el) => observer.observe(el));
  })();
</script>

<style>
  /* ─────────────────────────────────────────────
     SHARED
  ───────────────────────────────────────────── */
  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(20px, 5vw, 48px);
  }

  .eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #C6A24B;
    margin-bottom: 14px;
  }

  /* ─────────────────────────────────────────────
     SCROLL REVEAL
  ───────────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.68s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.68s cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─────────────────────────────────────────────
     HERO
  ───────────────────────────────────────────── */
  .contact-hero {
    padding-block: clamp(64px, 9vw, 100px) clamp(40px, 6vw, 64px);
  }

  .contact-hero__inner {
    max-width: 680px;
  }

  .contact-hero__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 600;
    color: #1E293B;
    letter-spacing: -0.028em;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .contact-hero__sub {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 400;
    color: #64748B;
    line-height: 1.72;
    max-width: 480px;
  }

  /* ─────────────────────────────────────────────
     BODY GRID
  ───────────────────────────────────────────── */
  .contact-body {
    padding-block: 0 clamp(80px, 11vw, 120px);
  }

  .contact-body__grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: clamp(48px, 7vw, 96px);
    align-items: start;
  }

  /* ─────────────────────────────────────────────
     LEFT — INFO BLOCKS
  ───────────────────────────────────────────── */
  .contact-info {
    position: sticky;
    top: 148px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .info-block {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .info-block__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(198, 162, 75, 0.1);
    border-radius: 12px;
    color: #C6A24B;
    margin-top: 2px;
  }

  .info-block__label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #94A3B8;
    margin-bottom: 6px;
  }

  .info-block__value {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 18px;
    font-weight: 500;
    color: #1E293B;
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .info-block__value:hover {
    color: #C6A24B;
  }

  .info-divider {
    height: 1px;
    background: rgba(30, 41, 59, 0.08);
    margin-block: 28px;
  }

  .info-block--meet {
    align-items: flex-start;
  }

  .info-block__desc {
    font-family: 'Inter', sans-serif;
    font-size: 14.5px;
    font-weight: 400;
    color: #64748B;
    line-height: 1.72;
    margin-bottom: 18px;
  }

  .info-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 20px;
    background: #1E293B;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.18s ease;
    box-shadow: 0 4px 14px rgba(30, 41, 59, 0.16);
  }

  .info-btn:hover {
    background: #0f172a;
    transform: translateY(-2px);
  }

  /* ─────────────────────────────────────────────
     RIGHT — FORM CARD
  ───────────────────────────────────────────── */
  .contact-form-wrap {
    background: rgba(255, 255, 255, 0.72);
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    border-radius: 28px;
    padding: clamp(32px, 5vw, 52px);
    box-shadow:
      0 1px 2px rgba(30, 41, 59, 0.04),
      0 12px 40px rgba(30, 41, 59, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .form-row--2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .form-label {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #475569;
    letter-spacing: 0.01em;
  }

  .form-input {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #1E293B;
    background: #F5F2EC;
    border: 1.5px solid rgba(30, 41, 59, 0.12);
    border-radius: 12px;
    padding: 13px 16px;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
  }

  .form-input::placeholder {
    color: #94A3B8;
  }

  .form-input:focus {
    border-color: rgba(198, 162, 75, 0.55);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(198, 162, 75, 0.12);
  }

  .form-select-wrap {
    position: relative;
  }

  .form-select {
    cursor: pointer;
    padding-right: 40px;
  }

  .form-select-arrow {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #94A3B8;
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.65;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 15px 32px;
    background: linear-gradient(135deg, #c6a24b 0%, #d4af5e 55%, #c6a24b 100%);
    background-size: 200% 100%;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 15.5px;
    font-weight: 500;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 4px 18px rgba(198, 162, 75, 0.30);
    transition: background-position 0.4s ease, transform 0.2s ease, box-shadow 0.2s ease;
    align-self: flex-start;
  }

  .form-submit:hover {
    background-position: 100% 0;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(198, 162, 75, 0.38);
  }

  /* ─────────────────────────────────────────────
     RESPONSIVE
  ───────────────────────────────────────────── */
  @media (max-width: 860px) {
    .contact-body__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .contact-info {
      position: static;
    }
  }

  @media (max-width: 540px) {
    .form-row--2 {
      grid-template-columns: 1fr;
    }

    .contact-hero__title br {
      display: none;
    }

    .form-submit {
      align-self: stretch;
    }
  }
</style>
