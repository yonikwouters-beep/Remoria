---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Remoria voor nabestaanden — Een blijvende plek voor elk kostbaar moment"
  description="Remoria maakt het toegankelijk om alle herinneringen samen te brengen op één veilige, serene plek. Start vandaag een digitale gedenkplek voor uw dierbare."
>
  <Navbar />

  <!-- ══════════════════════════════════════════════
       1. HERO
  ══════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading" data-reveal>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="hero__content" data-reveal>
        <p class="eyebrow">Remoria voor de nabestaanden</p>
        <h1 class="hero__title" id="hero-heading">
          Een blijvende plek<br />voor elk kostbaar<br />moment
        </h1>
        <p class="hero__body">
          Wanneer we iemand verliezen, blijven de herinneringen ons kostbaarste bezit.
          Maar vaak zitten die herinneringen verspreid: in oude fotoalbums, op verschillende
          smartphones of diep in ons geheugen. Remoria maakt het toegankelijk om alles samen
          te brengen op één veilige, serene plek.
        </p>
        <div class="hero__actions">
          <a href="/prijzen" class="btn btn--primary">
            Start een gedenkplek
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="https://remoria.eu/demo"
            class="btn btn--ghost"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="btn__play" aria-hidden="true">
              <svg width="9" height="11" viewBox="0 0 9 11" fill="currentColor">
                <path d="M0 0l9 5.5L0 11V0z"/>
              </svg>
            </span>
            Bekijk een voorbeeld
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       2. HOW IT WORKS
  ══════════════════════════════════════════════ -->
  <section class="how" id="hoe-werkt-het">
    <div class="container">

      <div class="how__header" data-reveal>
        <div class="how__divider" aria-hidden="true"></div>
        <p class="eyebrow eyebrow--center">Hoe het werkt</p>
        <h2 class="section-title">Zo creëer je een<br />blijvende plek</h2>
        <p class="section-sub">Het opzetten van een digitaal gedenkplek is eenvoudig.</p>
      </div>

      <div class="how__cards">

        <!-- Card 1 -->
        <div class="how-card" data-reveal data-reveal-delay="0">
          <div class="how-card__top">
            <div class="how-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="19" y1="8" x2="19" y2="14"/>
                <line x1="22" y1="11" x2="16" y2="11"/>
              </svg>
            </div>
            <span class="how-card__step">1</span>
          </div>
          <h3 class="how-card__title">Maak in een handomdraai de omgeving aan</h3>
          <p class="how-card__text">
            Start eenvoudig een persoonlijke gedenkplek. Binnen enkele minuten
            hebt u een veilige omgeving waar herinneringen samenkomen.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="how-card" data-reveal data-reveal-delay="80">
          <div class="how-card__top">
            <div class="how-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            </div>
            <span class="how-card__step">2</span>
          </div>
          <h3 class="how-card__title">Nodig je kring uit</h3>
          <p class="how-card__text">
            Deel de unieke link via sociale media platformen, of gebruik de persoonlijke
            QR-code. Deze code kun je bijvoorbeeld ook op het rouwprentje laten drukken,
            zodat vrienden en familie direct toegang hebben tot de omgeving.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="how-card" data-reveal data-reveal-delay="160">
          <div class="how-card__top">
            <div class="how-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <span class="how-card__step">3</span>
          </div>
          <h3 class="how-card__title">Deel, verbind en herinner</h3>
          <p class="how-card__text">
            Zodra je mensen zijn aangemeld kan iedereen zijn eigen foto's, video's of
            audiofragmenten uploaden. Via de chatfunctie of het plaatsen van een eerbetoon
            ontstaan er gesprekken en komen er verhalen naar boven die je misschien nog
            nooit gehoord had.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       3. FEATURES GRID
  ══════════════════════════════════════════════ -->
  <section class="fg">
    <div class="container">

      <!-- Header -->
      <div class="fg__header" data-reveal>
        <p class="eyebrow eyebrow--center">
          <span class="eyebrow__plus" aria-hidden="true">+</span> Alles wat u krijgt
        </p>
        <h2 class="section-title fg__title">
          Een complete omgeving voor blijvende herinneringen
        </h2>
        <p class="section-sub fg__sub">
          Remoria biedt nabestaanden een veilige en persoonlijke plek om herinneringen te bewaren,
          te delen en samen te koesteren. Ontdek wat er allemaal mogelijk is.
        </p>
      </div>

      <!-- Drie kaarten boven -->
      <div class="fg__top">

        <!-- Kaart 1: Mediacollectie -->
        <div class="fg-card" data-reveal data-reveal-delay="0">
          <div class="fg-card__head">
            <div class="fg-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
            <div>
              <h3 class="fg-card__title">Mediacollectie</h3>
              <p class="fg-card__sub">Bewaar en organiseer foto's, video's en audio.</p>
            </div>
          </div>
          <!-- Screenshot placeholder — vervang de div door een <img> naar wens -->
          <div class="fg-card__screen" aria-label="Screenshot placeholder Mediacollectie"></div>
        </div>

        <!-- Kaart 2: Community chat -->
        <div class="fg-card" data-reveal data-reveal-delay="80">
          <div class="fg-card__head">
            <div class="fg-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="fg-card__title">Community chat</h3>
              <p class="fg-card__sub">Deel verhalen en steun elkaar in een warme omgeving.</p>
            </div>
          </div>
          <div class="fg-card__screen" aria-label="Screenshot placeholder Community chat"></div>
        </div>

        <!-- Kaart 3: Eerbetonen -->
        <div class="fg-card" data-reveal data-reveal-delay="160">
          <div class="fg-card__head">
            <div class="fg-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <div>
              <h3 class="fg-card__title">Eerbetonen</h3>
              <p class="fg-card__sub">Breng een eerbetoon en laat bijzondere woorden achter.</p>
            </div>
          </div>
          <div class="fg-card__screen" aria-label="Screenshot placeholder Eerbetonen"></div>
        </div>

      </div>

      <!-- Brede kaart onder -->
      <div class="fg-wide" data-reveal>
        <div class="fg-wide__left">
          <div class="fg-wide__head">
            <div class="fg-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
            </div>
            <div>
              <h3 class="fg-card__title">Tastbaar maken</h3>
              <p class="fg-card__sub">Maak herinneringen tastbaar met een fotoboek.</p>
            </div>
          </div>

          <ul class="fg-steps">
            <li class="fg-step">
              <div class="fg-step__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
              </div>
              <div>
                <p class="fg-step__title">Selecteer momenten</p>
                <p class="fg-step__text">Kies de mooiste foto's en verhalen uit de collectie.</p>
              </div>
            </li>
            <li class="fg-step">
              <div class="fg-step__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 20h9"/>
                  <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                </svg>
              </div>
              <div>
                <p class="fg-step__title">Personaliseer</p>
                <p class="fg-step__text">Voeg teksten, lay-outs en thema's toe die bij jullie passen.</p>
              </div>
            </li>
            <li class="fg-step">
              <div class="fg-step__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 12V22H4V12"/>
                  <path d="M22 7H2v5h20V7z"/>
                  <path d="M12 22V7"/>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                </svg>
              </div>
              <div>
                <p class="fg-step__title">Ontvang een fotoboek</p>
                <p class="fg-step__text">Een blijvende herinnering om vast te houden en te koesteren.</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Screenshot placeholder — vervang door <img> naar wens -->
        <div class="fg-wide__screen" aria-label="Screenshot placeholder fotoboek"></div>
      </div>

      <!-- Trust footer -->
      <div class="fg__trust" data-reveal>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span>100% privé &amp; veilig</span>
        <span class="fg__trust-dot" aria-hidden="true">•</span>
        <span>Alleen familie en genodigden hebben toegang</span>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       4. QUOTE BANNER
  ══════════════════════════════════════════════ -->
  <section class="quote-banner">
    <div class="container">
      <div class="quote-banner__inner" data-reveal>
        <div class="quote-banner__overlay"></div>
        <div class="quote-banner__content">
          <span class="quote-banner__mark" aria-hidden="true">"</span>
          <blockquote class="quote-banner__quote">
            Herinneringen delen is liefde<br />een plek geven om te blijven bestaan.
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       5. FINAL CTA
  ══════════════════════════════════════════════ -->
  <section class="cta" data-reveal>
    <div class="container">
      <div class="cta__inner">
        <h2 class="cta__title">Klaar om een blijvende<br />plek te creëren?</h2>
        <p class="cta__sub">
          Start vandaag nog en nodig uw dierbaren uit om samen herinneringen te bewaren.
        </p>
        <a href="/prijzen" class="btn btn--primary btn--lg">
          Start een gedenkplek
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       6. TRUST BAR
  ══════════════════════════════════════════════ -->
  <section class="trust" data-reveal>
    <div class="container">
      <div class="trust__grid">

        <div class="trust-item">
          <div class="trust-item__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h4 class="trust-item__title">Veilig en privé</h4>
          <p class="trust-item__text">Uw omgeving is volledig besloten en beveiligd.</p>
        </div>

        <div class="trust-item">
          <div class="trust-item__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h4 class="trust-item__title">Altijd toegankelijk</h4>
          <p class="trust-item__text">Overal en altijd toegang voor u en uw dierbaren.</p>
        </div>

        <div class="trust-item">
          <div class="trust-item__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h4 class="trust-item__title">Met zorg gemaakt</h4>
          <p class="trust-item__text">Ontwikkeld met respect voor uw herinneringen.</p>
        </div>

        <div class="trust-item">
          <div class="trust-item__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <h4 class="trust-item__title">Tastbare herinneringen</h4>
          <p class="trust-item__text">Maak eenvoudig een prachtig fotoboek.</p>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<!-- ═══════════════════════════════════════════════════════════
     SCROLL REVEAL
═══════════════════════════════════════════════════════════ -->
<script>
  (function () {
    const els = document.querySelectorAll('[data-reveal]');
    if (!els.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const delay = (e.target as HTMLElement).dataset.revealDelay || '0';
            setTimeout(() => e.target.classList.add('is-visible'), Number(delay));
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12 }
    );

    els.forEach((el) => io.observe(el));
  })();
</script>

<style>
  /* ─── Tokens ──────────────────────────────────── */
  :root {
    --bg:        #F7F4EE;
    --ink:       #1E293B;
    --muted:     #6B7280;
    --gold:      #C6A24B;
    --gold-soft: rgba(198, 162, 75, 0.12);
    --card-bg:   rgba(255, 255, 255, 0.72);
    --radius-img: 28px;
    --radius-card: 20px;
  }

  /* ─── Base ─────────────────────────────────────── */
  section {
    background-color: var(--bg);
  }

  .container {
    max-width: 1160px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 56px);
  }

  /* ─── Reveal ───────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.72s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.72s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  /* ─── Typography ────────────────────────────────── */
  .eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 18px;
  }
  .eyebrow--center { display: block; text-align: center; }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.9rem, 3.2vw, 2.85rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .section-sub {
    font-family: 'Inter', sans-serif;
    font-size: clamp(15px, 1.4vw, 16px);
    line-height: 1.75;
    color: var(--muted);
  }

  /* ─── Buttons ───────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    cursor: pointer;
    border: none;
  }
  .btn:hover { transform: translateY(-2px); }

  .btn--primary {
    background: var(--ink);
    color: #fff;
    box-shadow: 0 4px 20px rgba(30, 41, 59, 0.2);
  }
  .btn--primary:hover {
    background: #0f172a;
    box-shadow: 0 8px 28px rgba(30, 41, 59, 0.28);
  }

  .btn--ghost {
    background: #fff;
    color: var(--ink);
    border: 1px solid rgba(30, 41, 59, 0.14);
    box-shadow: 0 1px 4px rgba(30, 41, 59, 0.06);
  }
  .btn--ghost:hover {
    border-color: rgba(30, 41, 59, 0.24);
    box-shadow: 0 4px 16px rgba(30, 41, 59, 0.1);
  }

  .btn--lg { padding: 16px 36px; font-size: 16px; }

  .btn__play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--ink);
    color: #fff;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ════════════════════════════════════════════
     HERO — full-bleed achtergrond zoals /over-ons
  ════════════════════════════════════════════ */
  .hero {
    position: relative;
    background-color: var(--bg);
    background-image: url('/Voor-nabestaanden-web.webp');
    background-size: cover;
    background-position: 66% 18%;
    background-repeat: no-repeat;
    min-height: clamp(520px, 64vw, 740px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      #F7F4EE 0%,
      rgba(247, 244, 238, 0.97) 26%,
      rgba(247, 244, 238, 0.82) 44%,
      rgba(247, 244, 238, 0.45) 62%,
      rgba(247, 244, 238, 0.08) 82%,
      rgba(247, 244, 238, 0) 100%
    );
  }

  .hero .container {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-block: clamp(64px, 9vw, 104px);
  }

  .hero__content {
    max-width: 520px;
  }

  .hero__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.2rem, 4.2vw, 3.8rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .hero__body {
    font-family: 'Inter', sans-serif;
    font-size: clamp(15px, 1.5vw, 16px);
