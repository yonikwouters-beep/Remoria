---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Remoria voor nabestaanden — Een blijvende plek voor elk kostbaar moment"
  description="Remoria maakt het toegankelijk om alle herinneringen samen te brengen op één veilige, serene plek. Start vandaag een digitale gedenkplek voor uw dierbare."
>
  <Navbar />

  <!-- ══════════════════════════════════════════════
       1. HERO
  ══════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading" data-reveal>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="hero__content" data-reveal>
        <p class="eyebrow">Remoria voor de nabestaanden</p>
        <h1 class="hero__title" id="hero-heading">
          Een blijvende plek<br />voor elk kostbaar<br />moment
        </h1>
        <p class="hero__body">
          Wanneer we iemand verliezen, blijven de herinneringen ons kostbaarste bezit.
          Maar vaak zitten die herinneringen verspreid: in oude fotoalbums, op verschillende
          smartphones of diep in ons geheugen. Remoria maakt het toegankelijk om alles samen
          te brengen op één veilige, serene plek.
        </p>
        <div class="hero__actions">
          <a href="#" class="btn btn--primary">
            Start een gedenkplek
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#" class="btn btn--ghost">
            <span class="btn__play" aria-hidden="true">
              <svg width="9" height="11" viewBox="0 0 9 11" fill="currentColor">
                <path d="M0 0l9 5.5L0 11V0z"/>
              </svg>
            </span>
            Bekijk een voorbeeld
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       2. HOW IT WORKS
  ══════════════════════════════════════════════ -->
  <section class="how" id="hoe-werkt-het">
    <div class="container">

      <div class="how__header" data-reveal>
        <div class="how__divider" aria-hidden="true"></div>
        <p class="eyebrow eyebrow--center">Hoe het werkt</p>
        <h2 class="section-title">Zo creëer je een<br />blijvende plek</h2>
        <p class="section-sub">Het opzetten van een digitaal gedenkplek is eenvoudig.</p>
      </div>

      <div class="how__cards">

        <!-- Card 1 -->
        <div class="how-card" data-reveal data-reveal-delay="0">
          <div class="how-card__top">
            <div class="how-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="19" y1="8" x2="19" y2="14"/>
                <line x1="22" y1="11" x2="16" y2="11"/>
              </svg>
            </div>
            <span class="how-card__step">1</span>
          </div>
          <h3 class="how-card__title">Maak in een handomdraai de omgeving aan</h3>
          <p class="how-card__text">
            Start eenvoudig een persoonlijke gedenkplek. Binnen enkele minuten
            hebt u een veilige omgeving waar herinneringen samenkomen.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="how-card" data-reveal data-reveal-delay="80">
          <div class="how-card__top">
            <div class="how-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            </div>
            <span class="how-card__step">2</span>
          </div>
          <h3 class="how-card__title">Nodig je kring uit</h3>
          <p class="how-card__text">
            Deel de unieke link via sociale media platformen, of gebruik de persoonlijke
            QR-code. Deze code kun je bijvoorbeeld ook op het rouwprentje laten drukken,
            zodat vrienden en familie direct toegang hebben tot de omgeving.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="how-card" data-reveal data-reveal-delay="160">
          <div class="how-card__top">
            <div class="how-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <span class="how-card__step">3</span>
          </div>
          <h3 class="how-card__title">Deel, verbind en herinner</h3>
          <p class="how-card__text">
            Zodra je mensen zijn aangemeld kan iedereen zijn eigen foto's, video's of
            audiofragmenten uploaden. Via de chatfunctie of het plaatsen van een eerbetoon
            ontstaan er gesprekken en komen er verhalen naar boven die je misschien nog
            nooit gehoord had.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       3. FEATURE SHOWCASE
  ══════════════════════════════════════════════ -->
  <section class="features">
    <div class="container features__grid">

      <div class="features__visual" data-reveal>
        <div class="features__img-wrap">
          <img
            src="/over-ons-voor-nabestaanden.webp"
            alt="Remoria platform — herinneringen bewaren en delen"
            class="features__img"
            loading="lazy"
            decoding="async"
            width="680"
            height="760"
          />
        </div>
      </div>

      <div class="features__list" data-reveal data-reveal-delay="80">

        <div class="feature-item">
          <div class="feature-item__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <div class="feature-item__body">
            <h3 class="feature-item__title">Memory Collection</h3>
            <p class="feature-item__text">
              Bouw samen aan een rijk archief. Upload foto's, video's en audiofragmenten.
            </p>
          </div>
        </div>
        <div class="feature-item__divider"></div>

        <div class="feature-item">
          <div class="feature-item__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <div class="feature-item__body">
            <h3 class="feature-item__title">Samen herdenken</h3>
            <p class="feature-item__text">
              Plaats persoonlijke rouwberichten of deel anekdotes. Via de geïntegreerde
              chatfunctie kunt u in een vertrouwde omgeving praten met anderen die de
              overledene ook hebben gekend. Zo steunt u elkaar en blijven verhalen leven.
            </p>
          </div>
        </div>
        <div class="feature-item__divider"></div>

        <div class="feature-item">
          <div class="feature-item__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <div class="feature-item__body">
            <h3 class="feature-item__title">Van digitaal naar tastbaar</h3>
            <p class="feature-item__text">
              Met Remoria zet u de verzamelde herinneringen in slechts enkele klikken om
              in een prachtig, kwalitatief fotoboek. Een tastbaar aandenken om op elk
              moment even vast te pakken.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       4. QUOTE BANNER
  ══════════════════════════════════════════════ -->
  <section class="quote-banner">
    <div class="container">
      <div class="quote-banner__inner" data-reveal>
        <div class="quote-banner__overlay"></div>
        <div class="quote-banner__content">
          <span class="quote-banner__mark" aria-hidden="true">"</span>
          <blockquote class="quote-banner__quote">
            Herinneringen delen is liefde<br />een plek geven om te blijven bestaan.
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       5. FINAL CTA
  ══════════════════════════════════════════════ -->
  <section class="cta" data-reveal>
    <div class="container">
      <div class="cta__inner">
        <h2 class="cta__title">Klaar om een blijvende<br />plek te creëren?</h2>
        <p class="cta__sub">
          Start vandaag nog en nodig uw dierbaren uit om samen herinneringen te bewaren.
        </p>
        <a href="#" class="btn btn--primary btn--lg">
          Start een gedenkplek
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       6. TRUST BAR
  ══════════════════════════════════════════════ -->
  <section class="trust" data-reveal>
    <div class="container">
      <div class="trust__grid">

        <div class="trust-item">
          <div class="trust-item__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h4 class="trust-item__title">Veilig en privé</h4>
          <p class="trust-item__text">Uw omgeving is volledig besloten en beveiligd.</p>
        </div>

        <div class="trust-item">
          <div class="trust-item__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h4 class="trust-item__title">Altijd toegankelijk</h4>
          <p class="trust-item__text">Overal en altijd toegang voor u en uw dierbaren.</p>
        </div>

        <div class="trust-item">
          <div class="trust-item__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h4 class="trust-item__title">Met zorg gemaakt</h4>
          <p class="trust-item__text">Ontwikkeld met respect voor uw herinneringen.</p>
        </div>

        <div class="trust-item">
          <div class="trust-item__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <h4 class="trust-item__title">Tastbare herinneringen</h4>
          <p class="trust-item__text">Maak eenvoudig een prachtig fotoboek.</p>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<!-- ═══════════════════════════════════════════════════════════
     SCROLL REVEAL
═══════════════════════════════════════════════════════════ -->
<script>
  (function () {
    const els = document.querySelectorAll('[data-reveal]');
    if (!els.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const delay = (e.target as HTMLElement).dataset.revealDelay || '0';
            setTimeout(() => e.target.classList.add('is-visible'), Number(delay));
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12 }
    );

    els.forEach((el) => io.observe(el));
  })();
</script>

<style>
  /* ─── Tokens ──────────────────────────────────── */
  :root {
    --bg:        #F7F4EE;
    --ink:       #1E293B;
    --muted:     #6B7280;
    --gold:      #C6A24B;
    --gold-soft: rgba(198, 162, 75, 0.12);
    --card-bg:   rgba(255, 255, 255, 0.72);
    --radius-img: 28px;
    --radius-card: 20px;
  }

  /* ─── Base ─────────────────────────────────────── */
  section {
    background-color: var(--bg);
  }

  .container {
    max-width: 1160px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 56px);
  }

  /* ─── Reveal ───────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.72s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.72s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  /* ─── Typography ────────────────────────────────── */
  .eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 18px;
  }
  .eyebrow--center { display: block; text-align: center; }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.9rem, 3.2vw, 2.85rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .section-sub {
    font-family: 'Inter', sans-serif;
    font-size: clamp(15px, 1.4vw, 16px);
    line-height: 1.75;
    color: var(--muted);
  }

  /* ─── Buttons ───────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    cursor: pointer;
    border: none;
  }
  .btn:hover { transform: translateY(-2px); }

  .btn--primary {
    background: var(--ink);
    color: #fff;
    box-shadow: 0 4px 20px rgba(30, 41, 59, 0.2);
  }
  .btn--primary:hover {
    background: #0f172a;
    box-shadow: 0 8px 28px rgba(30, 41, 59, 0.28);
  }

  .btn--ghost {
    background: #fff;
    color: var(--ink);
    border: 1px solid rgba(30, 41, 59, 0.14);
    box-shadow: 0 1px 4px rgba(30, 41, 59, 0.06);
  }
  .btn--ghost:hover {
    border-color: rgba(30, 41, 59, 0.24);
    box-shadow: 0 4px 16px rgba(30, 41, 59, 0.1);
  }

  .btn--lg { padding: 16px 36px; font-size: 16px; }

  .btn__play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--ink);
    color: #fff;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ════════════════════════════════════════════
     HERO — full-bleed achtergrond zoals /over-ons
  ════════════════════════════════════════════ */
  .hero {
    position: relative;
    background-color: var(--bg);
    background-image: url('/Voor-nabestaanden-web.webp');
    background-size: cover;
    background-position: 66% 28%;
    background-repeat: no-repeat;
    min-height: clamp(600px, 82vw, 920px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      #F7F4EE 0%,
      rgba(247, 244, 238, 0.97) 26%,
      rgba(247, 244, 238, 0.82) 44%,
      rgba(247, 244, 238, 0.45) 62%,
      rgba(247, 244, 238, 0.08) 82%,
      rgba(247, 244, 238, 0) 100%
    );
  }

  .hero .container {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-block: clamp(64px, 9vw, 104px);
  }

  .hero__content {
    max-width: 520px;
  }

  .hero__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.2rem, 4.2vw, 3.8rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .hero__body {
    font-family: 'Inter', sans-serif;
    font-size: clamp(15px, 1.5vw, 16px);
    line-height: 1.8;
    color: var(--muted);
    max-width: 460px;
    margin-bottom: 40px;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }

  /* ════════════════════════════════════════════
     HOW IT WORKS
  ════════════════════════════════════════════ */
  .how {
    padding: clamp(72px, 10vh, 112px) 0;
  }

  .how__header {
    text-align: center;
    max-width: 540px;
    margin: 0 auto clamp(52px, 7vh, 80px);
  }

  .how__divider {
    width: 36px;
    height: 2px;
    background: var(--gold);
    margin: 0 auto 20px;
    border-radius: 2px;
  }

  .how__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 2.5vw, 32px);
  }

  .how-card {
    background: var(--card-bg);
    border: 1px solid rgba(30, 41, 59, 0.07);
    border-radius: var(--radius-card);
    padding: clamp(28px, 3.5vw, 44px) clamp(24px, 3vw, 38px);
    box-shadow:
      0 1px 3px rgba(30, 41, 59, 0.05),
      0 12px 32px rgba(30, 41, 59, 0.07);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .how-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 4px 8px rgba(30, 41, 59, 0.06),
      0 20px 48px rgba(30, 41, 59, 0.11);
  }

  .how-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .how-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gold-soft);
    border-radius: 14px;
    color: var(--gold);
  }

  .how-card__step {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: rgba(198, 162, 75, 0.18);
    line-height: 1;
  }

  .how-card__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.35;
    margin-bottom: 14px;
  }

  .how-card__text {
    font-family: 'Inter', sans-serif;
    font-size: 14.5px;
    line-height: 1.75;
    color: var(--muted);
  }

  /* ════════════════════════════════════════════
     FEATURES
  ════════════════════════════════════════════ */
  .features {
    padding: clamp(72px, 10vh, 112px) 0;
  }

  .features__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(48px, 6vw, 88px);
    align-items: center;
  }

  .features__img-wrap {
    border-radius: var(--radius-img);
    overflow: hidden;
    box-shadow:
      0 2px 8px rgba(30, 41, 59, 0.06),
      0 28px 64px rgba(30, 41, 59, 0.12);
  }

  .features__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .features__img-wrap:hover .features__img {
    transform: scale(1.03);
  }

  .features__list {
    display: flex;
    flex-direction: column;
  }

  .feature-item {
    display: flex;
    gap: 20px;
    padding: clamp(24px, 3vh, 32px) 0;
  }

  .feature-item__icon {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gold-soft);
    border-radius: 12px;
    color: var(--gold);
    margin-top: 2px;
  }

  .feature-item__title {
    font-family: 'Playfair Display', Georgia, serif;
