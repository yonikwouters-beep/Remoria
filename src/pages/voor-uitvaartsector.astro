---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Remoria voor de uitvaartsector — Innovatieve nazorg die families verbindt"
  description="Als begrafenisondernemer bent u de rots in de branding tijdens de moeilijkste dagen van een familie. Met Remoria biedt u een moderne, digitale gedenkplek aan uw dienstverlening."
>
  <Navbar />

  <!-- ══════════════════════════════════════════════
       1. HERO
  ══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero__grid">

      <div class="hero__content" data-reveal>
        <p class="eyebrow">Remoria voor de uitvaartsector</p>
        <h1 class="hero__title">
          Innovatieve nazorg<br />die families verbindt
        </h1>
        <p class="hero__body">
          Onderscheid uw kantoor met een unieke digitale gedenkplek voor de nabestaanden.
          Een waardevolle toevoeging aan uw nazorg die troost biedt zonder extra werklast.
        </p>
        <div class="hero__actions">
          <a href="/contact" class="btn btn--gold">Word partner</a>
          <button
            type="button"
            class="btn btn--outline"
            data-cal-link="remoria/30min"
            data-cal-namespace="30min"
            data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
          >
            <span class="btn__play" aria-hidden="true">
              <svg width="10" height="12" viewBox="0 0 10 12" fill="currentColor">
                <path d="M0 0l10 6-10 6V0z"/>
              </svg>
            </span>
            Plan een demo
          </button>
        </div>
      </div>

      <div class="hero__visual" data-reveal data-reveal-delay="100">
        <img
          src="/Uitvaartsector-remoria.webp"
          alt="Digitale gedenkplek — lichtgevende boog als symbool van verbinding"
          class="hero__img"
          loading="eager"
          decoding="async"
        />
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       2. VALUE PROP
  ══════════════════════════════════════════════ -->
  <section class="value-prop">
    <div class="container value-prop__inner" data-reveal>
      <div class="value-prop__icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </div>
      <h2 class="value-prop__title">
        Versterk uw dienstverlening<br />met een digitale gedenkplek
      </h2>
      <p class="value-prop__sub">
        Op een toegankelijke manier herinneringen met elkaar kunnen delen.
        Remoria is het platform dat u als professionele partner kunt aanbieden
        om die behoefte in te vullen.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       3. HOW IT WORKS
  ══════════════════════════════════════════════ -->
  <section class="how" id="hoe-werkt-het" aria-labelledby="how-heading">
    <div class="container">
      <div class="how__header" data-reveal>
        <p class="eyebrow">Naadloze integratie in jouw dienstverlening</p>
        <h2 class="how__title" id="how-heading">Zo werkt het</h2>
      </div>

      <!-- Icon timeline row -->
      <div class="how__timeline" aria-hidden="true" data-reveal>
        <div class="how__timeline-line"></div>
        <div class="how__icon-row">
          <div class="how__icon-bubble">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <div class="how__icon-bubble">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="how__icon-bubble">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
              <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
          </div>
          <div class="how__icon-bubble">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Steps text row -->
      <div class="how__steps">
        <div class="how__step" data-reveal data-reveal-delay="0">
          <div class="how__step-header">
            <span class="how__step-num">1</span>
            <h3 class="how__step-title">Eenvoudige onboarding</h3>
          </div>
          <p class="how__step-desc">
            Meld je aan via ons partnerformulier met je bedrijfsgegevens. Zodra
            je account geactiveerd is, heb je direct toegang tot je eigen
            professionele omgeving.
          </p>
        </div>

        <div class="how__step" data-reveal data-reveal-delay="80">
          <div class="how__step-header">
            <span class="how__step-num">2</span>
            <h3 class="how__step-title">Creëer domeinen voor je families en ontvang commissies</h3>
          </div>
          <p class="how__step-desc">
            Voor elke uitvaart die je verzorgt, maak je in enkele seconden een
            nieuw, beveiligd domein aan.
          </p>
        </div>

        <div class="how__step" data-reveal data-reveal-delay="160">
          <div class="how__step-header">
            <span class="how__step-num">3</span>
            <h3 class="how__step-title">Beheer alles via je dashboard</h3>
          </div>
          <p class="how__step-desc">
            In je overzichtelijke dashboard behoud je de volledige controle. Je
            ziet in één oogopslag welke omgevingen actief zijn en hoe de
            community's groeien. Hier heb je ook direct inzicht in je commissies.
          </p>
        </div>

        <div class="how__step" data-reveal data-reveal-delay="240">
          <div class="how__step-header">
            <span class="how__step-num">4</span>
            <h3 class="how__step-title">Directe bron voor de ceremonie</h3>
          </div>
          <p class="how__step-desc">
            Heb je beeldmateriaal nodig voor de afscheidsbijeenkomst? In het
            dashboard kun je eenvoudig de door familie en vrienden geüploade
            foto's in hoge kwaliteit downloaden.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       4. FEATURES
  ══════════════════════════════════════════════ -->
  <section class="features" aria-labelledby="features-heading">
    <div class="container features__grid">

      <div class="feat-card" data-reveal>
        <div class="feat-card__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
        <div class="feat-card__body">
          <h3 class="feat-card__title">Memory Collection als extra service</h3>
          <p class="feat-card__desc">
            Bied nabestaanden een centrale plek voor foto's, video's en
            audiofragmenten. U geeft hen de tools om een rijk, digitaal archief
            op te bouwen.
          </p>
        </div>
      </div>

      <div class="feat-card" data-reveal data-reveal-delay="80">
        <div class="feat-card__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="feat-card__body">
          <h3 class="feat-card__title">Een interactieve community</h3>
          <p class="feat-card__desc">
            Faciliteer verbinding. Via de chatfunctie en de mogelijkheid om
            rouwberichten te plaatsen, creëert u een veilige omgeving waar de
            familie en hun vrienden samen kunnen rouwen en herinneringen delen.
          </p>
        </div>
      </div>

      <div class="feat-card" data-reveal data-reveal-delay="160">
        <div class="feat-card__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <div class="feat-card__body">
          <h3 class="feat-card__title">Maak het tastbaar met het fotoboek</h3>
          <p class="feat-card__desc">
            Remoria maakt van de digitale collectie met slechts enkele klikken
            een hoogwaardig fotoboek. Een blijvende herinnering om te koesteren.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       5. CTA BANNER
  ══════════════════════════════════════════════ -->
  <section class="cta-banner" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-banner__card">
        <div class="cta-banner__overlay" aria-hidden="true"></div>
        <div class="cta-banner__inner" data-reveal>
          <blockquote class="cta-banner__quote" id="cta-heading">
            "Onderscheid uw uitvaartcentrum en bied Remoria aan als blijvende plek
            voor troost en herinnering."
          </blockquote>
          <div class="cta-banner__cta-block">
            <div class="cta-banner__actions">
              <a href="/contact" class="btn btn--gold">Word partner</a>
              <a href="/contact" class="btn btn--outline-light">
                Neem contact op
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
            <p class="cta-banner__legal">
              <a
                href="/Remoria-Verwerkersovereenkomst-Bijlage-AV.pdf"
                target="_blank"
                rel="noopener noreferrer"
              >Verwerkersovereenkomst (bijlage bij de algemene voorwaarden)</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.eu/embed/embed.js", "init");
  Cal("init", "30min", {origin:"https://app.cal.eu"});
  Cal.config = Cal.config || {};
  Cal.config.forwardQueryParams = true;

  Cal.ns["30min"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
</script>

<script>
  (function () {
    const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const el = e.target as HTMLElement;
            const delay = el.dataset.revealDelay ? parseInt(el.dataset.revealDelay) : 0;
            setTimeout(() => el.classList.add('is-visible'), delay);
            obs.unobserve(el);
          }
        });
      },
      { threshold: 0.1 }
    );
    els.forEach((el) => obs.observe(el));
  })();
</script>

<style>
  /* ─────────────────────────────────────────────
     SHARED
  ───────────────────────────────────────────── */
  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(20px, 5vw, 48px);
  }

  .eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #C6A24B;
    margin-bottom: 14px;
  }

  /* ── Scroll reveal ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 26px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 500;
    border-radius: 999px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: transform 0.18s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .btn--gold {
    background: linear-gradient(135deg, #c6a24b 0%, #d4af5e 55%, #c6a24b 100%);
    background-size: 200% 100%;
    color: #fff;
    box-shadow: 0 4px 18px rgba(198, 162, 75, 0.32);
    transition: background-position 0.4s ease, transform 0.18s ease, box-shadow 0.2s ease;
  }
  .btn--gold:hover {
    background-position: 100% 0;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(198, 162, 75, 0.42);
  }

  .btn--outline {
    background: transparent;
    color: #1E293B;
    border: 1.5px solid rgba(30, 41, 59, 0.22);
  }
  .btn--outline:hover {
    background: rgba(30, 41, 59, 0.05);
    border-color: rgba(30, 41, 59, 0.4);
    transform: translateY(-2px);
  }

  .btn--outline-light {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
  }
  .btn--outline-light:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.55);
    transform: translateY(-2px);
  }

  .btn__play {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: #1E293B;
    border-radius: 50%;
    color: #fff;
    flex-shrink: 0;
  }

  /* ─────────────────────────────────────────────
     1. HERO
  ───────────────────────────────────────────── */
  .hero {
    overflow: hidden;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(32px, 5vw, 64px);
    padding-block: clamp(56px, 8vw, 88px);
  }

  .hero__content {
    max-width: 520px;
  }

  .hero__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: #1E293B;
    letter-spacing: -0.025em;
    line-height: 1.12;
    margin-bottom: 20px;
  }

  .hero__body {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #475569;
    line-height: 1.75;
    margin-bottom: 36px;
    max-width: 440px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__img {
    width: 100%;
    max-height: 540px;
    object-fit: contain;
    object-position: center;
    border-radius: 24px;
    display: block;
  }

  /* ─────────────────────────────────────────────
     2. VALUE PROP
  ───────────────────────────────────────────── */
  .value-prop {
    padding-block: clamp(72px, 10vw, 104px);
    text-align: center;
  }

  .value-prop__inner {
    max-width: 640px;
  }

  .value-prop__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(198, 162, 75, 0.1);
    border: 1px solid rgba(198, 162, 75, 0.25);
    color: #C6A24B;
    margin-bottom: 24px;
  }

  .value-prop__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 500;
    color: #1E293B;
    letter-spacing: -0.022em;
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .value-prop__sub {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #64748B;
    line-height: 1.75;
  }

  /* ─────────────────────────────────────────────
     3. HOW IT WORKS
  ───────────────────────────────────────────── */
  .how {
    padding-block: clamp(56px, 8vw, 80px) clamp(64px, 9vw, 96px);
    background: linear-gradient(180deg, #F5F2EC 0%, #EDE9DF 100%);
  }

  .how__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .how__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 500;
    color: #1E293B;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  /* ── Icon timeline ── */
  .how__timeline {
    position: relative;
    margin-bottom: 28px;
  }

  .how__timeline-line {
    position: absolute;
    top: 50%;
    left: calc(12.5% - 22px);
    right: calc(12.5% - 22px);
    height: 1px;
    background: rgba(198, 162, 75, 0.25);
    transform: translateY(-50%);
    z-index: 0;
  }

  .how__icon-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    position: relative;
    z-index: 1;
  }

  .how__icon-bubble {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background: #F5F2EC;
    border: 1.5px solid rgba(198, 162, 75, 0.22);
    border-radius: 14px;
    color: #1E293B;
    margin-inline: auto;
    box-shadow: 0 2px 8px rgba(30, 41, 59, 0.06);
  }

  /* ── Steps ── */
  .how__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    align-items: start;
  }

  .how__step {
    padding: 0 8px;
  }

  .how__step-header {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 10px;
  }

  .how__step-num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #C6A24B;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    margin-top: 2px;
  }

  .how__step-title {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #1E293B;
    line-height: 1.4;
  }

  .how__step-desc {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #64748B;
    line-height: 1.72;
    padding-left: 30px;
  }

  /* ─────────────────────────────────────────────
     4. FEATURES
  ───────────────────────────────────────────── */
  .features {
    padding-block: clamp(48px, 7vw, 72px);
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feat-card {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 20px;
    padding: clamp(22px, 3vw, 32px);
    box-shadow:
      0 1px 2px rgba(30, 41, 59, 0.04),
      0 8px 24px rgba(30, 41, 59, 0.07);
    transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.28s ease;
  }

  .feat-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 2px 4px rgba(30, 41, 59, 0.06),
      0 16px 40px rgba(30, 41, 59, 0.11);
  }

  .feat-card__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(198, 162, 75, 0.1);
    border-radius: 13px;
    color: #C6A24B;
  }

  .feat-card__body {
    flex: 1;
  }

  .feat-card__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 17px;
    font-weight: 500;
    color: #1E293B;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .feat-card__desc {
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    color: #64748B;
    line-height: 1.72;
  }

  /* ─────────────────────────────────────────────
     5. CTA BANNER
