---
---

<section class="cta">
  <div class="cta__clouds" aria-hidden="true"></div>

  <span class="star star--1" aria-hidden="true">✦</span>
  <span class="star star--2" aria-hidden="true">✦</span>
  <span class="star star--3" aria-hidden="true">+</span>
  <span class="star star--4" aria-hidden="true">✦</span>
  <span class="star star--5" aria-hidden="true">+</span>

  <div class="cta__container">
    <div class="cta__mark" aria-hidden="true">
      <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M16 104V48C16 26.46 31.46 9 52 9C72.54 9 88 26.46 88 48V104" stroke="rgba(255,255,255,0.45)" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M36 104V52C36 38.19 42.27 26 52 26C61.73 26 68 38.19 68 52V104" stroke="rgba(255,255,255,0.25)" stroke-width="1.8" stroke-linecap="round"/>
        <circle cx="52" cy="38" r="4" fill="#C6A24B" opacity="0.85"/>
        <path d="M52 28L53.5 32.5L58 33L54.5 36L56 40.5L52 38L48 40.5L49.5 36L46 33L50.5 32.5L52 28Z" fill="rgba(255,255,255,0.35)"/>
      </svg>
    </div>

    <h2 class="cta__heading">
      Herinneringen vervagen niet,<br />
      als je ze deelt.
    </h2>
    <p class="cta__subtext">
      Begin vandaag nog met het verzamelen en koesteren van herinneringen.
    </p>

    <a href="/prijzen" class="cta__btn">
      Start een gedenkplek
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>

    <p class="cta__note">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <rect x="3" y="6" width="8" height="7" rx="1.5" stroke="rgba(255,255,255,0.45)" stroke-width="1.2"/>
        <path d="M5 6V4.5C5 3.12 6.12 2 7.5 2C8.88 2 10 3.12 10 4.5V6" stroke="rgba(255,255,255,0.45)" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      Veilig, privé en met liefde gemaakt.
    </p>
  </div>
</section>

<style>
  .cta {
    position: relative;
    background: #1E293B;
    padding: clamp(72px, 12vw, 88px) clamp(20px, 4vw, 40px) clamp(80px, 12vw, 96px);
    text-align: center;
    overflow: hidden;
  }

  .cta__clouds {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 90% 55% at 50% 100%, rgba(15, 23, 42, 0.95) 0%, transparent 58%),
      radial-gradient(ellipse 70% 40% at 20% 85%, rgba(30, 41, 59, 0.5) 0%, transparent 45%),
      radial-gradient(ellipse 60% 35% at 80% 88%, rgba(30, 41, 59, 0.45) 0%, transparent 42%);
    opacity: 0.9;
  }

  .star {
    position: absolute;
    color: rgba(255, 255, 255, 0.22);
    font-size: 16px;
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  .star--1 { top: 16%; left: 11%; font-size: 12px; }
  .star--2 { top: 26%; right: 14%; font-size: 20px; color: rgba(198,162,75,0.45); }
  .star--3 { top: 52%; left: 7%; font-size: 18px; }
  .star--4 { bottom: 26%; right: 9%; font-size: 11px; color: rgba(198,162,75,0.35); }
  .star--5 { top: 68%; right: 20%; font-size: 14px; }

  .cta__container {
    position: relative;
    z-index: 2;
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  .cta__mark {
    width: 88px;
    height: 88px;
    margin-bottom: 6px;
    opacity: 0.95;
  }

  .cta__heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(26px, 3.8vw, 40px);
    font-weight: 500;
    line-height: 1.22;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .cta__subtext {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.58);
    max-width: 420px;
    margin-top: -2px;
  }

  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: #C6A24B;
    color: #fff;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 500;
    border-radius: 999px;
    text-decoration: none;
    margin-top: 6px;
    box-shadow: 0 6px 24px rgba(198, 162, 75, 0.35);
    transition: background-color 0.2s ease, transform 0.18s ease, box-shadow 0.2s ease;
  }

  .cta__btn:hover {
    background: #b8922e;
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(198, 162, 75, 0.42);
  }

  .cta__note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    font-family: 'Inter', sans-serif;
    font-size: 12.5px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.42);
    margin-top: 4px;
  }

  @media (max-width: 540px) {
    .cta { padding: 72px 24px 80px; }
    .cta__mark { width: 72px; height: 72px; }
  }
</style>
