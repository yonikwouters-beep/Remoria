---
---

<section class="benefits">
  <div class="benefits__container">

    <!-- Nabestaanden -->
    <div class="panel panel--left">
      <div class="panel__row">
        <div class="panel__text">
          <div class="panel__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C6A24B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <p class="panel__label">VOOR NABESTAANDEN</p>
          <h2 class="panel__heading">Samen herinneren,<br />in alle rust.</h2>

          <ul class="panel__list">
            <li>
              <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Alles op één veilige plek
            </li>
            <li>
              <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Deel met wie jij kiest
            </li>
            <li>
              <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Blijvende herinneringen voor de toekomst
            </li>
            <li>
              <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Eenvoudig en toegankelijk voor iedereen
            </li>
          </ul>

          <a href="#" class="panel__btn">
            Meer voor nabestaanden
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="panel__visual">
          <div class="phone-mockup">
            <div class="phone-mockup__screen">
              <div class="phone-screen__header">
                <div class="phone-screen__avatar"></div>
                <div>
                  <p class="phone-screen__greeting">Welkom,</p>
                  <p class="phone-screen__name">Anna</p>
                </div>
              </div>
              <div class="phone-screen__img"></div>
              <div class="phone-screen__lines">
                <span></span><span></span><span class="short"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Uitvaartsector -->
    <div class="panel panel--right">
      <div class="panel__row">
        <div class="panel__text">
          <div class="panel__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C6A24B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18"/>
              <path d="M9 21V9"/>
            </svg>
          </div>
          <p class="panel__label">VOOR DE UITVAARTSECTOR</p>
          <h2 class="panel__heading">Innovatie die<br />zorg versterkt.</h2>

          <ul class="panel__list">
            <li>
              <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Bied families een unieke, persoonlijke gedenkplek aan
            </li>
            <li>
              <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Breng herinneringen samen die anders verloren gaan
            </li>
            <li>
              <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Ondersteun het rouwproces met een blijvende bron van troost
            </li>
            <li>
              <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Eenvoudig beheer via uw dashboard met een aantrekkelijk commissiemodel
            </li>
          </ul>

          <a href="#" class="panel__btn">
            Ontdek het partnerschap
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="panel__visual">
          <div class="laptop-mockup">
            <div class="laptop-mockup__screen">
              <div class="laptop-screen__bar">
                <div class="laptop-screen__dots"><span></span><span></span><span></span></div>
                <p class="laptop-screen__title">Remoria</p>
              </div>
              <div class="laptop-screen__body">
                <p class="laptop-screen__label">Overzicht</p>
                <div class="laptop-screen__stats">
                  <div class="laptop-stat">
                    <span class="laptop-stat__num">128</span>
                    <span class="laptop-stat__desc">Herinneringen</span>
                  </div>
                  <div class="laptop-stat">
                    <span class="laptop-stat__num">342</span>
                    <span class="laptop-stat__desc">Bijdragers</span>
                  </div>
                </div>
                <div class="laptop-screen__rows">
                  <span></span><span></span><span class="short"></span>
                </div>
              </div>
            </div>
            <div class="laptop-mockup__base"></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .benefits {
    background: #F5F2EC;
    padding: 0 clamp(20px, 4vw, 40px) clamp(64px, 10vw, 100px);
  }

  .benefits__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .panel {
    border-radius: 20px;
    padding: 40px 36px 40px;
    overflow: hidden;
  }

  .panel--left {
    background: #EDE9DF;
  }

  .panel--right {
    background: #E5EDF3;
  }

  .panel__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: end;
  }

  .panel__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(198, 162, 75, 0.12);
    border-radius: 14px;
    margin-bottom: 12px;
  }

  .panel__label {
    font-family: 'Inter', sans-serif;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #C6A24B;
    margin-bottom: 12px;
  }

  .panel__heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(24px, 2.6vw, 32px);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #1E293B;
    margin-bottom: 22px;
  }

  .panel__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
  }

  .panel__list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    font-weight: 400;
    color: #475569;
    line-height: 1.45;
  }

  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: rgba(198, 162, 75, 0.15);
    border-radius: 50%;
    color: #C6A24B;
    flex-shrink: 0;
  }

  .panel__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    background: #1E293B;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    font-weight: 500;
    border-radius: 999px;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.18s ease;
  }

  .panel__btn:hover {
    background: #0f172a;
    transform: translateY(-2px);
  }

  .panel__visual {
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  .phone-mockup {
    width: 150px;
    background: #1E293B;
    border-radius: 26px;
    padding: 10px;
    box-shadow: 0 24px 48px rgba(30, 41, 59, 0.2);
  }

  .phone-mockup__screen {
    background: #F5F2EC;
    border-radius: 16px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .phone-screen__header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .phone-screen__avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, #C6A24B, #e8c97a);
  }

  .phone-screen__greeting { font-size: 8px; color: #94A3B8; }
  .phone-screen__name { font-size: 12px; font-weight: 600; color: #1E293B; }

  .phone-screen__img {
    height: 72px;
    background: linear-gradient(135deg, #ddd6c8, #ede9df);
    border-radius: 8px;
  }

  .phone-screen__lines { display: flex; flex-direction: column; gap: 5px; }
  .phone-screen__lines span {
    display: block; height: 5px; background: #E2DCCE; border-radius: 3px;
  }
  .phone-screen__lines span.short { width: 60%; }

  .laptop-mockup {
    width: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    filter: drop-shadow(0 20px 40px rgba(30, 41, 59, 0.16));
  }

  .laptop-mockup__screen {
    width: 100%;
    background: #1E293B;
    border-radius: 10px 10px 0 0;
    padding: 6px;
  }

  .laptop-screen__bar {
    background: #F5F2EC;
    border-radius: 5px 5px 0 0;
    padding: 5px 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .laptop-screen__dots { display: flex; gap: 3px; }
  .laptop-screen__dots span {
    width: 5px; height: 5px; border-radius: 50%; background: #CBD5E1;
  }

  .laptop-screen__title {
    font-size: 8px; font-weight: 600; color: #94A3B8; letter-spacing: 0.05em;
  }

  .laptop-screen__body {
    background: #F8F7F4;
    padding: 10px;
    border-radius: 0 0 5px 5px;
  }

  .laptop-screen__label {
    font-size: 8px; font-weight: 600; color: #1E293B; margin-bottom: 8px;
  }

  .laptop-screen__stats { display: flex; gap: 14px; margin-bottom: 10px; }
  .laptop-stat { display: flex; flex-direction: column; gap: 1px; }
  .laptop-stat__num { font-size: 15px; font-weight: 700; color: #1E293B; line-height: 1; }
  .laptop-stat__desc { font-size: 7px; color: #94A3B8; }

  .laptop-screen__rows { display: flex; flex-direction: column; gap: 4px; }
  .laptop-screen__rows span {
    display: block; height: 4px; background: #E2DCCE; border-radius: 2px;
  }
  .laptop-screen__rows span.short { width: 55%; }

  .laptop-mockup__base {
    width: 110%;
    height: 8px;
    background: #1E293B;
    border-radius: 0 0 4px 4px;
    clip-path: polygon(5% 0%, 95% 0%, 100% 100%, 0% 100%);
  }

  @media (max-width: 1100px) {
    .benefits__container { gap: 16px; }
    .panel { padding: 32px 28px 36px; }
  }

  @media (max-width: 900px) {
    .benefits__container { grid-template-columns: 1fr; }
    .panel__row { grid-template-columns: 1fr; gap: 24px; }
    .panel__visual { order: 2; padding-top: 12px; justify-content: center; }
    .panel__btn { width: 100%; justify-content: center; }
  }

  @media (max-width: 480px) {
    .panel { padding: 28px 20px 32px; border-radius: 16px; }
  }
</style>
