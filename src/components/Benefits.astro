---
---

<section class="benefits">
  <div class="benefits__container">

    <!-- Nabestaanden -->
    <div class="panel panel--left">
      <div class="panel__text">
        <div class="panel__icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C6A24B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <p class="panel__label">VOOR NABESTAANDEN</p>
        <h2 class="panel__heading">Samen herinneren,<br />samen helen.</h2>

        <ul class="panel__list">
          <li>
            <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            Alles op één veilige plek
          </li>
          <li>
            <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            Deel met wie jij kiest
          </li>
          <li>
            <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            Blijvende herinneringen voor later
          </li>
          <li>
            <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            Toegankelijk op elk moment
          </li>
        </ul>

        <a href="/voor-nabestaanden" class="panel__btn">
          Meer voor nabestaanden
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="panel__visual panel__visual--phone">
        <img
          src="/Phone-background.webp"
          alt="Remoria app op smartphone"
          class="phone-img"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- Uitvaartsector -->
    <div class="panel panel--right">
      <div class="panel__text">
        <div class="panel__icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C6A24B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M3 9h18"/>
            <path d="M9 21V9"/>
          </svg>
        </div>
        <p class="panel__label">VOOR DE UITVAARTSECTOR</p>
        <h2 class="panel__heading">Innovatie die<br />zorg versterkt.</h2>

        <ul class="panel__list">
          <li>
            <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            Bied nabestaanden een digitale plek
          </li>
          <li>
            <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            Verhoog betrokkenheid en nazorg
          </li>
          <li>
            <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            Efficiënt en gebruiksvriendelijk platform
          </li>
          <li>
            <span class="check-icon"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            Volledig in lijn met jouw dienstverlening
          </li>
        </ul>

        <a href="/voor-uitvaartsector" class="panel__btn">
          Meer voor uitvaartorganisaties
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="panel__visual panel__visual--laptop">
        <img
          src="/laptop-portaal-website.webp"
          alt="Remoria platform op laptop"
          class="laptop-img"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

  </div>
</section>

<style>
  .benefits {
    background: #F5F2EC;
    padding: 0 clamp(20px, 4vw, 40px) clamp(64px, 10vw, 100px);
    width: 100%;
    max-width: 100%;
  }

  .benefits__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  /* ── Panel base ── */
  .panel {
    border-radius: 24px;
    padding: clamp(28px, 3.5vw, 44px) clamp(24px, 3vw, 40px) 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 480px;
  }

  .panel--left {
    background-color: #EDE9DF;
    background-image: url('/flowers-background.webp');
    background-repeat: no-repeat;
    background-size: 55%;
    background-position: bottom left;
    position: relative;
  }

  .panel--right {
    background: #E5EDF3;
  }

  /* ── Text block ── */
  .panel__text {
    flex: 0 0 auto;
  }

  .panel__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(198, 162, 75, 0.12);
    border-radius: 14px;
    margin-bottom: 14px;
  }

  .panel__label {
    font-family: 'Inter', sans-serif;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #C6A24B;
    margin-bottom: 10px;
  }

  .panel__heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: #1E293B;
    margin-bottom: 20px;
  }

  .panel__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
    margin-bottom: 24px;
  }

  .panel__list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    font-weight: 400;
    color: #475569;
    line-height: 1.45;
  }

  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: rgba(198, 162, 75, 0.15);
    border-radius: 50%;
    color: #C6A24B;
    flex-shrink: 0;
  }

  .panel__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    background: #1E293B;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    font-weight: 500;
    border-radius: 999px;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.18s ease;
    margin-bottom: clamp(20px, 3vw, 32px);
  }

  .panel__btn:hover {
    background: #0f172a;
    transform: translateY(-2px);
  }

  /* ── Visuals ── */
  .panel__visual {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    min-height: 200px;
    overflow: visible;
  }

  /* Phone — gekanteld zoals in referentie */
  .panel__visual--phone {
    justify-content: flex-end;
    align-items: flex-end;
    padding-right: 8px;
  }

  .phone-img {
    width: clamp(140px, 28%, 200px);
    height: auto;
    display: block;
    transform: rotate(4deg) translateY(4px);
    transform-origin: bottom center;
    filter: drop-shadow(0 24px 40px rgba(30, 41, 59, 0.18));
    border-radius: 28px;
  }

  /* Laptop — volledig zichtbaar, licht gekanteld */
  .panel__visual--laptop {
    justify-content: center;
    align-items: flex-end;
    padding: 0 4px;
  }

  .laptop-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
    transform: perspective(800px) rotateX(3deg) translateY(4px);
    transform-origin: bottom center;
    filter: drop-shadow(0 20px 36px rgba(30, 41, 59, 0.16));
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .benefits__container { gap: 16px; }
    .panel { padding: 28px 24px 0; }
  }

  @media (max-width: 900px) {
    .benefits__container { grid-template-columns: 1fr; }

    .panel {
      min-height: auto;
      padding-bottom: 0;
    }

    .panel--left {
      background-size: 45%;
    }

    .panel__visual {
      min-height: 180px;
      justify-content: center;
    }

    .phone-img {
      width: clamp(120px, 40%, 180px);
    }

    .laptop-img {
      max-width: 360px;
    }

    .panel__btn { width: 100%; justify-content: center; }
  }

  @media (max-width: 480px) {
    .panel { border-radius: 16px; padding: 24px 20px 0; }

    .panel--left {
      background-size: 55%;
    }

    .phone-img {
      width: 140px;
    }

    .laptop-img {
      max-width: 280px;
    }
  }
</style>
