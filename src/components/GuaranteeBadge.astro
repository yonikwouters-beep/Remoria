---
export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<p class:list={['guarantee-badge', className]}>
  <span class="guarantee-badge__icon" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    </svg>
  </span>
  <span class="guarantee-badge__text">14 dagen niet tevreden? Geld terug — zonder gedoe</span>
</p>

<style>
  .guarantee-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    padding: 12px 18px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(198, 162, 75, 0.28);
    border-radius: 999px;
    box-shadow: 0 2px 12px rgba(30, 41, 59, 0.06);
  }

  .guarantee-badge__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(198, 162, 75, 0.14);
    color: #C6A24B;
  }

  .guarantee-badge__text {
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    font-weight: 500;
    color: #1E293B;
    line-height: 1.35;
  }

  @media (max-width: 480px) {
    .guarantee-badge {
      align-items: flex-start;
      border-radius: 16px;
      padding: 12px 14px;
    }

    .guarantee-badge__text {
      font-size: 13px;
    }
  }
</style>
